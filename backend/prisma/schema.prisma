generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Profile {
  id          String       @id @db.Uuid
  email       String       @unique
  displayName String?
  photoURL    String?
  role        String       @default("user")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  stories     Story[]
  credits     UserCredits?
  apiKeys     ApiKey[]
}

model ApiKey {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @db.Uuid
  user         Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider     String
  label        String?
  encryptedKey String   @db.Text
  iv           String
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, provider, label])
}

model Story {
  id             String    @id @default(uuid()) @db.Uuid
  authorId       String    @db.Uuid
  author         Profile   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  title          String
  summary        String?   @db.Text
  coverImage     String?
  status         String    @default("draft")
  genre          String?
  theme          String?
  setting        String?
  mcName         String?
  mcGender       String?
  mcBio          String?   @db.Text
  writingStyle   String?
  crueltyLevel   String?
  aiInstructions String?   @db.Text
  blueprintJson  Json?                          // AI-generated blueprint (persist để reload)
  views          Int       @default(0)
  likes          Int       @default(0)
  rating         Float     @default(0.0)
  isFeatured     Boolean   @default(false)
  chapters       Chapter[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Chapter {
  id           String   @id @default(uuid()) @db.Uuid
  storyId      String   @db.Uuid
  story        Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  chapterIndex Int
  title        String?
  content      String   @db.Text
  wordCount    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model CraftLesson {
  id         String   @id @default(uuid()) @db.Uuid
  title      String
  rule       String   @db.Text
  stage      String
  appliesTo  Json?
  weight     Float    @default(1.0)
  lastSeenAt DateTime @default(now())
}

model UserCredits {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @unique @db.Uuid
  user             Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  totalTokensUsed  BigInt   @default(0)
  dailyTokensLimit Int      @default(100000)
  lastResetDate    DateTime @default(now())
}
