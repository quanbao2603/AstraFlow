# =============================================
#  AstraFlow Backend - Environment Template
#  Sao chép file này thành .env và điền giá trị thật
#  cp env.template .env
# =============================================

# SERVER
PORT=3001

# SUPABASE (AUTH)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_JWT_SECRET=your_supabase_jwt_secret

# POSTGRES (CORE)
# postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:your_password@your_host:5432/astraflow?schema=public"

# NEO4J (LORE)
NEO4J_URI=neo4j+s://your-instance-id.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password
NEO4J_DATABASE=your-instance-id
AURA_INSTANCEID=your-instance-id
AURA_INSTANCENAME=AstraFlow
